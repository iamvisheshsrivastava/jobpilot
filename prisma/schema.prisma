generator client {
  provider = "prisma-client-js"
}

// Local dev: SQLite (no setup needed)
// Production: change provider to "postgresql" and remove @db.Text / @db.Date annotations
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// SQLite doesn't support native enums — stored as String with app-level validation
// When migrating to PostgreSQL, uncomment the enum blocks below and add them back to fields

// enum JobStatus  { IN_PROGRESS APPLIED INTERVIEW LOOK_AGAIN REJECTED NOT_SUITABLE EXPIRED_FILLED }
// enum JobPriority { SUPER_HIGH HIGH MEDIUM LOW }
// enum LlmProvider { GROQ OPENROUTER }

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  categories   Category[]
  apiKeys      ApiKey[]
  profile      UserProfile?

  @@map("users")
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  summary        String?
  cvText         String?  @map("cv_text")
  experience     String?  // JSON array of ExperienceEntry
  education      String?  // JSON array of EducationEntry
  skills         String?  // JSON array of strings
  languages      String?  // JSON array of LanguageEntry
  certifications String?  // JSON array of strings
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String   // "GROQ" | "OPENROUTER" or any LlmProvider
  encryptedKey String   @map("encrypted_key")
  modelName    String?  @map("model_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("api_keys")
}

model Category {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs         Job[]

  @@unique([userId, name])
  @@map("categories")
}

model Job {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  jobNumber   Int      @map("job_number")
  title       String
  company     String?
  link        String?
  status           String   @default("IN_PROGRESS") // JobStatus enum values
  priority         String   @default("MEDIUM")       // JobPriority enum values
  comments         String?
  deadline         DateTime?
  dateAdded        DateTime @default(now()) @map("date_added")
  starred          Boolean  @default(false)
  duplicateGroupId String?  @map("duplicate_group_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  note        JobNote?
  history     JobHistory[]

  @@map("jobs")
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String   @unique @map("job_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_notes")
}

model JobHistory {
  id           String   @id @default(cuid())
  jobId        String   @map("job_id")
  fieldChanged String   @map("field_changed")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  changedAt    DateTime @default(now()) @map("changed_at")

  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_history")
}
