{
  "manifest_version": 3,
  "name": "JobPilot",
  "version": "2.0.1",
  "description": "Save jobs and get AI suitability analysis. Sync with your JobPilot account.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://jobpilot-lime.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://*.myworkday.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://*.myworkday.com/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
