generator client {
  provider = "prisma-client-js"
}

// Local dev: SQLite (no setup needed)
// Production: change provider to "postgresql" and remove @db.Text / @db.Date annotations
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// SQLite doesn't support native enums — stored as String with app-level validation
// When migrating to PostgreSQL, uncomment the enum blocks below and add them back to fields

// enum JobStatus  { IN_PROGRESS APPLIED INTERVIEW OFFER LOOK_AGAIN REJECTED NOT_SUITABLE EXPIRED_FILLED }
// enum JobPriority { SUPER_HIGH HIGH MEDIUM LOW }
// enum LlmProvider { GROQ OPENROUTER OPENAI ANTHROPIC GEMINI }

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash     String      @map("password_hash")
  telegramChatId   String?     @map("telegram_chat_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  categories     Category[]
  apiKeys        ApiKey[]
  profile        UserProfile?
  resumeVersions ResumeVersion[]
  gmailToken     GmailToken?
  notifications  Notification[]

  @@map("users")
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  summary        String?
  cvText         String?  @map("cv_text")
  experience     String?  // JSON array of ExperienceEntry
  education      String?  // JSON array of EducationEntry
  skills         String?  // JSON array of strings
  languages      String?  // JSON array of LanguageEntry
  certifications String?  // JSON array of strings
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  provider     String   // "GROQ" | "OPENROUTER" or any LlmProvider
  encryptedKey String   @map("encrypted_key")
  modelName    String?  @map("model_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("api_keys")
}

model Category {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs         Job[]

  @@unique([userId, name])
  @@map("categories")
}

model Job {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  jobNumber   Int      @map("job_number")
  title       String
  company     String?
  link        String?
  status           String   @default("IN_PROGRESS") // JobStatus enum values
  priority         String   @default("MEDIUM")       // JobPriority enum values
  comments         String?
  deadline         DateTime?
  dateAdded        DateTime @default(now()) @map("date_added")
  starred          Boolean  @default(false)
  duplicateGroupId String?  @map("duplicate_group_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Kanban / extended fields
  recruiterName      String?  @map("recruiter_name")
  recruiterEmail     String?  @map("recruiter_email")
  recruiterLinkedIn  String?  @map("recruiter_linkedin")
  resumeUsed         String?  @map("resume_used")
  applicationNotes   String?  @map("application_notes")
  resumeVersionId    String?  @map("resume_version_id")

  category     Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion? @relation("JobResume", fields: [resumeVersionId], references: [id])
  note         JobNote?
  history      JobHistory[]

  @@map("jobs")
}

model ResumeVersion {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  fileUrl   String?  @map("file_url")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[] @relation("JobResume")

  @@map("resume_versions")
}

model JobNote {
  id        String   @id @default(cuid())
  jobId     String   @unique @map("job_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_notes")
}

model JobHistory {
  id           String   @id @default(cuid())
  jobId        String   @map("job_id")
  fieldChanged String   @map("field_changed")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  changedAt    DateTime @default(now()) @map("changed_at")

  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_history")
}
model GmailToken {
  id           String    @id @default(cuid())
  userId       String    @unique @map("user_id")
  email        String
  accessToken  String    @map("access_token")
  refreshToken String    @map("refresh_token")
  expiresAt    DateTime  @map("expires_at")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_tokens")
}

model Notification {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  type         String    // REJECTION | INTERVIEW | OFFER | APPLICATION_CONFIRMATION | OTHER
  title        String
  body         String
  read         Boolean   @default(false)
  emailFrom    String?   @map("email_from")
  emailSubject String?   @map("email_subject")
  emailDate    DateTime? @map("email_date")
  gmailMsgId   String?   @unique @map("gmail_msg_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
